{
  "version": 2,
  "builds": [
    { "src": "api/*.js",   "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/news",    "dest": "/api/news.js"    },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/article", "dest": "/api/article.js" },
    { "src": "/",            "dest": "/index.html"     },
    { "src": "/article",     "dest": "/index.html"     }
  ]
}
